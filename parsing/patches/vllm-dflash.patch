@@ -0,0 +1,190 @@
+# SPDX-License-Identifier: Apache-2.0
+"""Qwen3VL DFlash draft model adapter for vLLM.
+
+This module intentionally reuses the existing text-only Qwen3 DFlash draft
+implementation.  Qwen3VL target execution still owns the visual tower and the
+merged multimodal embeddings; the draft model only consumes token ids, target
+hidden states, positions, and KV-cache slots in the same way as the existing
+LLM DFlash path.
+
+The two VL-specific compatibility points are:
+1. HuggingFace Qwen3VL configs wrap the language config in ``text_config``.
+   The existing DFlashQwen3ForCausalLM expects a Qwen3 text config directly.
+2. Qwen3VL uses MRoPE positions shaped ``(3, seq_len)``.  For generated text
+   draft tokens, all three axes advance together, so the DFlash draft can use
+   the first axis as the text RoPE position.  Unsupported shapes fall back to
+   the original positions tensor and let the base implementation raise.
+"""
+
+from __future__ import annotations
+
+from collections.abc import Iterable
+
+import torch
+from transformers import PretrainedConfig
+
+from vllm.config import VllmConfig
+from vllm.model_executor.models.qwen3_dflash import DFlashQwen3ForCausalLM
+from vllm.multimodal.inputs import NestedTensors
+
+
+def _select_text_positions(positions: torch.Tensor) -> torch.Tensor:
+    """Convert Qwen3VL MRoPE positions to text RoPE positions for DFlash.
+
+    Qwen3VL passes positions as ``(3, seq_len)`` when MRoPE is enabled.  The
+    draft model has no vision tower and uses the existing Qwen3 rotary path,
+    which expects a one-dimensional position vector.  Generated text positions
+    have synchronized t/h/w axes, so axis 0 is the compatible text position.
+    """
+
+    if isinstance(positions, torch.Tensor) and positions.dim() == 2:
+        if positions.shape[0] == 3:
+            return positions[0]
+    return positions
+
+
+def _as_text_dflash_config(vllm_config: VllmConfig):
+    """Temporarily expose Qwen3VL ``text_config`` as draft ``hf_config``.
+
+    The existing DFlash implementation reads
+    ``vllm_config.speculative_config.draft_model_config.hf_config`` during
+    construction.  For Qwen3VL checkpoints this object is the multimodal config,
+    while the draft layers live under ``text_config``.  Mutating the draft model
+    config during construction keeps the rest of vLLM's speculative plumbing
+    unchanged and avoids duplicating DFlashQwen3Model.
+    """
+
+    draft_model_config = vllm_config.speculative_config.draft_model_config
+    original_hf_config = draft_model_config.hf_config
+    text_config = getattr(original_hf_config, "text_config", None)
+    if text_config is None:
+        return original_hf_config, None
+    if isinstance(text_config, dict):
+        text_config = PretrainedConfig(**text_config)
+        setattr(original_hf_config, "text_config", text_config)
+
+    # vLLM speculative config construction inspects the top-level draft
+    # config before this adapter is instantiated. Mirror common language-model
+    # attributes from text_config so Qwen3VL draft configs look like ordinary
+    # EAGLE/DFlash configs to that generic path.
+    for name in (
+        "vocab_size",
+        "hidden_size",
+        "num_hidden_layers",
+        "num_attention_heads",
+        "num_key_value_heads",
+        "head_dim",
+        "rms_norm_eps",
+        "max_position_embeddings",
+        "bos_token_id",
+        "eos_token_id",
+        "pad_token_id",
+    ):
+        if hasattr(text_config, name) and not hasattr(original_hf_config, name):
+            setattr(original_hf_config, name, getattr(text_config, name))
+
+    # DFlash metadata is usually stored on the draft top-level config.  Copy it
+    # onto text_config so DFlashQwen3Model can find it unchanged.
+    for name in (
+        "dflash_config",
+        "eagle_config",
+        "draft_vocab_size",
+        "logit_scale",
+        "target_hidden_size",
+    ):
+        if hasattr(original_hf_config, name) and not hasattr(text_config, name):
+            setattr(text_config, name, getattr(original_hf_config, name))
+
+    draft_model_config.hf_config = text_config
+    return original_hf_config, text_config
+
+
+def _restore_hf_config(vllm_config: VllmConfig, original_hf_config) -> None:
+    vllm_config.speculative_config.draft_model_config.hf_config = original_hf_config
+
+
+class DFlashQwen3VLForConditionalGeneration(DFlashQwen3ForCausalLM):
+    """DFlash draft adapter for Qwen3VL speculative decoding.
+
+    The class deliberately does not implement a visual tower.  In DFlash, the
+    target Qwen3VL model has already encoded multimodal context; the draft uses
+    target hidden states through ``precompute_and_store_context_kv`` and only
+    needs the language-model DFlash layers.
+    """
+
+    def __init__(self, *, vllm_config: VllmConfig, prefix: str = ""):
+        original_hf_config, text_config = _as_text_dflash_config(vllm_config)
+        try:
+            super().__init__(vllm_config=vllm_config, prefix=prefix)
+        finally:
+            _restore_hf_config(vllm_config, original_hf_config)
+        self.vl_config = original_hf_config
+        self.text_config = text_config or original_hf_config
+
+    def embed_input_ids(
+        self,
+        input_ids: torch.Tensor,
+        multimodal_embeddings: NestedTensors | None = None,
+        is_multimodal: torch.Tensor | None = None,
+    ) -> torch.Tensor:
+        # Multimodal embeddings are owned by the target Qwen3VL path.  The draft
+        # only embeds generated/query text tokens, matching the LLM DFlash path.
+        return self.model.embed_input_ids(input_ids)
+
+    def forward(
+        self,
+        input_ids: torch.Tensor,
+        positions: torch.Tensor,
+        inputs_embeds: torch.Tensor | None = None,
+    ) -> torch.Tensor:
+        return self.model(input_ids, _select_text_positions(positions), inputs_embeds)
+
+    def precompute_and_store_context_kv(
+        self,
+        context_states: torch.Tensor,
+        context_positions: torch.Tensor,
+        context_slot_mapping: torch.Tensor | list[torch.Tensor | None] | None = None,
+    ) -> None:
+        self.model.precompute_and_store_context_kv(
+            context_states,
+            _select_text_positions(context_positions),
+            context_slot_mapping,
+        )
+
+    def load_weights(self, weights: Iterable[tuple[str, torch.Tensor]]):
+        """Load Qwen3VL-language or plain DFlash weight names.
+
+        Supported incoming prefixes:
+        - ``model.language_model.`` from HF Qwen3VL-style checkpoints
+        - ``language_model.`` from vLLM-mapped VL checkpoints
+        - plain DFlash Qwen3 names, passed through unchanged
+
+        Vision tower weights are skipped because this draft adapter has no
+        visual tower by design.
+        """
+
+        remapped: list[tuple[str, torch.Tensor]] = []
+        skip_prefixes = (
+            "visual.",
+            "model.visual.",
+            "vision_tower.",
+            "model.vision_tower.",
+            "model.language_model.",
+            "language_model.",
+            "model.model.language_model.",
+        )
+        strip_prefixes = (
+            "draft_model.",
+            "model.draft_model.",
+        )
+
+        for name, tensor in weights:
+            if name.startswith(skip_prefixes):
+                continue
+            for prefix in strip_prefixes:
+                if name.startswith(prefix):
+                    name = name[len(prefix) :]
+                    break
+            remapped.append((name, tensor))
+
+        return super().load_weights(remapped)
