+    (cache_dir / "build.ninja").write_text(ninja_content)
+
+    result = subprocess.run(
+        ["ninja", "-j1"],
+        cwd=str(cache_dir),
+        capture_output=True,
+        text=True,
+    )
+    if result.returncode != 0:
+        raise RuntimeError(
+            f"FMHA plan compilation failed:\n"
+            f"stdout: {result.stdout}\n"
+            f"stderr: {result.stderr}"
+        )
