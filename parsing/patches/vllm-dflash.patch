+try:
+    ROTARY_OP = torch.ops._C.rotary_embedding.default
+except AttributeError:
+    ROTARY_OP = None
+FLASHINFER_ROTARY_OP = torch.ops.vllm.flashinfer_rotary_embedding.default
+
+QUANT_OPS: dict[QuantKey, OpOverload] = {}
+for _quant_key, _quant_name in (
+    (kFp8StaticTensorSym, "static_scaled_fp8_quant"),
+    (kFp8DynamicTensorSym, "dynamic_scaled_fp8_quant"),
+    (kFp8DynamicTokenSym, "dynamic_per_token_scaled_fp8_quant"),
+):
+    try:
+        QUANT_OPS[_quant_key] = getattr(torch.ops._C, _quant_name).default
+    except AttributeError:
+        pass
+
+if hasattr(torch.ops._C, "per_token_group_fp8_quant"):
+    QUANT_OPS[kFp8Dynamic128Sym] = torch.ops._C.per_token_group_fp8_quant.default  # noqa: E501
+    QUANT_OPS[kFp8Dynamic64Sym] = torch.ops._C.per_token_group_fp8_quant.default  # noqa: E501
+
+if current_platform.is_cuda() and hasattr(torch.ops._C, "scaled_fp4_quant"):
+    try:
+        QUANT_OPS[kNvfp4Dynamic] = torch.ops._C.scaled_fp4_quant.out  # noqa: E501
+    except AttributeError:
+        # Legacy CUDA extensions may expose the functional op but not the
+        # newer out overload. NVFP4 matching is optional for Qwen3 DFlash.
+        pass
